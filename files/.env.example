# Backblaze B2 — sign up free at backblaze.com/cloud-storage, create a bucket + app key
B2_KEY_ID=your_b2_key_id_here
B2_APP_KEY=your_b2_app_key_here
B2_BUCKET=your_bucket_name_here
B2_REGION=us-east-005

# Groq — free tier, no billing required, get a key at console.groq.com
GROQ_API_KEY=your_groq_key_here

# Hugging Face — free tier, fine-grained token with "Make calls to Inference Providers" permission
HF_TOKEN=your_hf_token_here

DATABASE_URL=sqlite:///./forge_gate.db
MAX_RETRY_ATTEMPTS=3

# Optional — lock down POST /jobs and reference-upload endpoints. If unset,
# every request is allowed through (fine for local dev / open demo). Set this
# in Railway and pass the same value as X-API-Key from the frontend to enable.
API_SHARED_SECRET=
